# Course materials (PDFs, extracted text) — kept locally, not committed
course/

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.mypy_cache/
.ruff_cache/

# ---------- Docker ----------
*.pid

# ---------- Kubernetes ----------
# Never commit kubeconfigs or generated secrets
kubeconfig
kubeconfig.*
*.kubeconfig
**/secrets-*.yaml.local
**/*.secret.yaml

# ---------- Terraform ----------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars
crash.log

# ---------- AWS / cloud creds ----------
.aws/
*.pem
*.key
credentials
.envrc

# ---------- Secrets / env ----------
.env
.env.*
!.env.example
# Demo 18 ships a non-secret .env file used by docker compose; allow it
!demos/18-docker-compose/.env

# ---------- Editors / OS ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------- Node ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Logs / temp ----------
*.log
logs/
tmp/
.cache/